# --- Weights & corpora: NEVER in the tree (the monorepo's load-bearing rule) ---
# They regenerate from committed code and live in release artifacts / R2,
# referenced by registry.json. Per-project .gitignores repeat these for sparse
# clones; this enforces it repo-wide.
*.pt
*.bin
*.onnx
*.pkl
*.vocab.json

# --- Python ---
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
env/
# uv.lock IS committed (reproducible installs) — do not ignore it.

# --- Generated chart output (dataviz renders these on demand) ---
tools/dataviz/output/

# --- ONNX export output (core/export/export.py; artifacts publish to R2) ---
projects/*/dist/

# --- Node ---
node_modules/

# --- OS ---
.DS_Store
.wrangler/

# --- Claude worktrees (session-created, never repo content) ---
.claude/worktrees/
